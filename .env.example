# CRGS Lab — Monorepo Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below (your actual keys)
#   3. NEVER commit .env — it is in .gitignore
#
# The docker-compose.yml reads from .env automatically when you run
# any make target or docker-compose command.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your OpenAI API key — used by core/llm_binding.py (hypothesis generation),
# core/ingest_arxiv.py (arXiv abstract extraction), and core/red_team.py
# (adversarial review). Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# SerpApi key — used by Phase 3+ patent landscape search
# Get yours at: https://serpapi.com/manage-api-key
# Leave blank to skip patent search.
SERPAPI_KEY=

# ── INTERNAL (do not change unless you know what you're doing) ────────────────

# Neo4j credentials — must match docker-compose.yml
NEO4J_AUTH=neo4j/StrictPassword123!
NEO4J_PASSWORD=StrictPassword123!

# Constitutional engine behaviour
ENFORCE_STRICT_CONSTITUTION=True
MAX_REVISION_LOOPS=3
LLM_TEMPERATURE=0.0
