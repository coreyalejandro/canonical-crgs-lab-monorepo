# CRGS Lab — Monorepo Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below (your actual keys)
#   3. NEVER commit .env — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM BACKEND (choose one) ──────────────────────────────────────────────────

# "lmstudio" = LM Studio local server — FREE, no credits needed (DEFAULT)
# "ollama"   = Ollama local server    — FREE, no credits needed
# "openai"   = OpenAI cloud API       — requires credits at platform.openai.com
LLM_BACKEND=lmstudio

# LM Studio settings (only used when LLM_BACKEND=lmstudio)
# LM Studio must be running with the server enabled (port 1234)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# Speed optimized (4B): google/gemma-4-e4b
# Quality optimized (12B): google/gemma-4-12b
LM_STUDIO_MODEL=google/gemma-4-e4b

# Ollama settings (only used when LLM_BACKEND=ollama)
# Run: ollama pull qwen2.5:7b  then: ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ── OPTIONAL (OpenAI cloud fallback) ──────────────────────────────────────────

# Only required when LLM_BACKEND=openai
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# SerpApi key — Phase 8 patent novelty search (google_patents engine)
# Leave blank to run simulated novelty check (no blocking, bootstrapped tier)
# Get yours at: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Audit ledger tenant ID — scopes the local audit log file (Phase 7)
TENANT_ID=enterprise_client_001

# AWS QLDB ledger name — optional, enables cloud audit shipping (Phase 7)
# Leave blank for file-only audit (bootstrapped tier)
AWS_QLDB_LEDGER_NAME=

# ── INTERNAL (do not change unless you know what you're doing) ────────────────

# Neo4j credentials — must match docker-compose.yml
NEO4J_AUTH=neo4j/StrictPassword123!
NEO4J_PASSWORD=StrictPassword123!

# Constitutional engine behaviour
ENFORCE_STRICT_CONSTITUTION=True
MAX_REVISION_LOOPS=3
LLM_TEMPERATURE=0.0
