# ============================================
# CALSP Bootstrapped Prototype Configuration
# ============================================
# Copy this file to .env and configure for your environment
# DO NOT commit .env to version control

# --------------------------------------------
# Application Settings
# --------------------------------------------
NODE_ENV=development
PORT=3000
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --------------------------------------------
# IRB Compliance (CRITICAL)
# --------------------------------------------
# ⚠️ DO NOT set IRB_APPROVED=true without documented IRB approval
IRB_APPROVED=false
IRB_PROTOCOL_NUMBER=
IRB_APPROVAL_DATE=
IRB_EXPIRATION_DATE=

# ⚠️ DO NOT set COLLECT_REAL_DATA=true without IRB approval
COLLECT_REAL_DATA=false

# --------------------------------------------
# LLM Provider Configuration
# --------------------------------------------
# Choose one: huggingface, openai, anthropic, local
LLM_PROVIDER=huggingface

# Hugging Face (Free tier available)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# OpenAI (Paid, optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Paid, optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Local LLM (Advanced, optional)
LOCAL_MODEL_PATH=./models/llama-3.1-8b-instruct.gguf
LOCAL_MODEL_TYPE=llama

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# Development (SQLite)
DATABASE_URL=sqlite:///./data/pilot.db

# Production (PostgreSQL - recommended for megaproject)
# DATABASE_URL=postgresql://username:password@localhost:5432/calsp_db

# Database pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --------------------------------------------
# Data Collection Settings
# --------------------------------------------
# Participant compensation (USD)
PARTICIPANT_COMPENSATION=50

# Data retention period (days)
DATA_RETENTION_DAYS=1095

# Anonymous participant IDs
USE_ANONYMOUS_IDS=true
ID_PREFIX=P

# --------------------------------------------
# Accessibility Settings
# --------------------------------------------
# Default contrast mode: standard, high, extra-high
DEFAULT_CONTRAST=high

# Default font size (px)
DEFAULT_FONT_SIZE=16

# Enable screen reader optimizations
ENABLE_SCREEN_READER=true

# Enable dyslexia-friendly font
ENABLE_DYSLEXIA_FONT=true

# Enable text-to-speech
ENABLE_TTS=true

# Enable voice input (experimental)
ENABLE_VOICE_INPUT=false

# --------------------------------------------
# Constitutional AI Settings
# --------------------------------------------
# Path to constitutional rules
CONSTITUTIONAL_RULES_PATH=./constitutional-rules/base-rules.yaml

# Constitutional Compliance Index (CCI) threshold
CCI_THRESHOLD=0.95

# Enable real-time CCI monitoring
ENABLE_CCI_MONITORING=true

# Adversarial testing frequency (hours)
ADVERSARIAL_TEST_FREQUENCY=24

# --------------------------------------------
# Monitoring and Logging
# --------------------------------------------
# Enable audit logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=./data/audit-logs/

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# Enable error tracking (Sentry, optional)
SENTRY_DSN=

# --------------------------------------------
# Security Settings
# --------------------------------------------
# Secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_change_in_production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting (requests per minute)
RATE_LIMIT=60

# Enable HTTPS redirect (production only)
FORCE_HTTPS=false

# --------------------------------------------
# Email Configuration (Optional)
# --------------------------------------------
# For sending delayed recall reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@calsp.org

# --------------------------------------------
# Continuous Human Audit Engine (CHAE)
# --------------------------------------------
# Enable CHAE (weekly audit buddy for bootstrapped version)
ENABLE_CHAE=true

# CHAE review frequency (hours)
CHAE_REVIEW_FREQUENCY=168

# CHAE contact email
CHAE_CONTACT_EMAIL=chae@calsp.org

# --------------------------------------------
# Research Instruments
# --------------------------------------------
# Path to instruments
INSTRUMENTS_PATH=./instruments/

# Minimal NAP (10 items for bootstrapped version)
NAP_VERSION=minimal

# Enable adaptive difficulty
ENABLE_ADAPTIVE_DIFFICULTY=true

# --------------------------------------------
# Data Export Settings
# --------------------------------------------
# De-identification settings
DEIDENTIFY_ON_EXPORT=true
REMOVE_TIMESTAMPS=false
AGGREGATE_DEMOGRAPHICS=true

# Export format: csv, json, parquet
EXPORT_FORMAT=csv

# --------------------------------------------
# Development Settings
# --------------------------------------------
# Enable debug mode (shows detailed errors)
DEBUG=false

# Enable hot reload
HOT_RELOAD=true

# Mock LLM responses (for testing without API calls)
MOCK_LLM=false

# Synthetic data mode (demo without IRB)
SYNTHETIC_DATA_MODE=true

# --------------------------------------------
# Feature Flags
# --------------------------------------------
# Enable experimental features
ENABLE_VOICE_MODE=false
ENABLE_VISUAL_MODE=true
ENABLE_GAMIFICATION=false
ENABLE_SOCIAL_FEATURES=false

# --------------------------------------------
# Analytics (Optional)
# --------------------------------------------
# Google Analytics (optional, for public demo site)
GA_TRACKING_ID=

# Plausible Analytics (privacy-friendly alternative)
PLAUSIBLE_DOMAIN=

# --------------------------------------------
# Deployment Settings
# --------------------------------------------
# Deployment platform: local, render, fly, railway, docker
DEPLOYMENT_PLATFORM=local

# Health check endpoint
HEALTH_CHECK_PATH=/health

# Graceful shutdown timeout (seconds)
SHUTDOWN_TIMEOUT=30

# --------------------------------------------
# Backup Settings
# --------------------------------------------
# Enable automatic backups
ENABLE_AUTO_BACKUP=true

# Backup frequency (hours)
BACKUP_FREQUENCY=24

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup destination
BACKUP_PATH=./backups/

# --------------------------------------------
# Community Settings
# --------------------------------------------
# Discord webhook for community notifications (optional)
DISCORD_WEBHOOK_URL=

# GitHub repository for issue tracking
GITHUB_REPO=yourusername/constitutional-adaptive-learning

# --------------------------------------------
# Compliance and Legal
# --------------------------------------------
# Privacy policy URL
PRIVACY_POLICY_URL=https://calsp.org/privacy

# Terms of service URL
TERMS_OF_SERVICE_URL=https://calsp.org/terms

# Data protection officer contact
DPO_EMAIL=dpo@calsp.org

# GDPR compliance mode (for EU participants)
GDPR_MODE=false

# --------------------------------------------
# Notes
# --------------------------------------------
# 1. Never commit .env to version control
# 2. Use strong, unique SECRET_KEY in production
# 3. Rotate API keys regularly
# 4. Review security settings before deployment
# 5. Ensure IRB approval before enabling data collection
# 6. Test with synthetic data first
# 7. Monitor audit logs daily during data collection
# 8. Back up data regularly
# 9. Document all configuration changes
# 10. Consult with your institution's IT security team

# ============================================
# End of Configuration
# ============================================